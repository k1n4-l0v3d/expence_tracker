# =============================================================
# Скопируй этот файл в .env и заполни своими данными:
#   cp .env.example .env
# =============================================================


# ── База данных (PostgreSQL) ──────────────────────────────────
# Формат: postgresql://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/ИМЯ_БД
# Локально (DBeaver/pgAdmin): хост = localhost, порт = 5432
# На Render: строку подключения берёшь из раздела "Connect" своей БД
DATABASE_URL=postgresql://postgres:пароль@localhost:5432/postgres


# ── Секретный ключ Flask ──────────────────────────────────────
# Используется для подписи сессий и CSRF-токенов.
# Сгенерируй случайную строку: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=замени-на-случайную-строку-минимум-32-символа


# ── ИИ-помощник (Groq) ───────────────────────────────────────
# Бесплатный API для модели Llama3.
# Получить ключ: https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Сетевые настройки Flask (опционально) ────────────────────
# По умолчанию сервер запускается на 127.0.0.1:5000
# Раскомментируй и измени если нужно другое поведение
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
# FLASK_DEBUG=false
